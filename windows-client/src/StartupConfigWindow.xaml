<Window x:Class="WindowsStepGuide.Client.StartupConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="模型配置"
        Width="420"
        MinHeight="260"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF7F7F2">
    <Border Padding="16">
        <StackPanel>
            <TextBlock Text="启动前配置"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />
            <TextBlock Text="请输入本次运行要使用的大模型类型。API Key 可选（留空将走本地安全回退）。"
                       Foreground="#FF666666"
                       TextWrapping="Wrap" />
            <TextBlock Text="模型类型"
                       FontWeight="Bold"
                       Margin="0,16,0,6" />
            <TextBox x:Name="ModelTypeTextBox"
                     Margin="0,0,0,8" />
            <TextBlock Text="API Key（可选）"
                       FontWeight="Bold"
                       Margin="0,8,0,6" />
            <PasswordBox x:Name="ApiKeyPasswordBox" />
            <TextBlock x:Name="ValidationTextBlock"
                       Foreground="#FF9C2F2F"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap" />
            <UniformGrid Columns="2"
                         Margin="0,16,0,0">
                <Button Content="取消"
                        Height="32"
                        IsCancel="True"
                        Margin="0,0,6,0"
                        Click="CancelButton_Click" />
                <Button Content="确认并进入"
                        Height="32"
                        IsDefault="True"
                        Margin="6,0,0,0"
                        Click="ConfirmButton_Click" />
            </UniformGrid>
        </StackPanel>
    </Border>
</Window>
