<Window x:Class="WindowsStepGuide.Client.StartupConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="模型配置"
        Width="480"
        MinHeight="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF7F7F2">
    <Border Padding="16">
        <StackPanel>
            <TextBlock Text="启动前配置"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />
            <TextBlock Text="支持会员令牌或 API Key。你可以切换提供商并手动输入模型与 Base URL。"
                       Foreground="#FF666666"
                       TextWrapping="Wrap" />
            <TextBlock Text="鉴权方式"
                       FontWeight="Bold"
                       Margin="0,16,0,6" />
            <ComboBox x:Name="AuthModeComboBox"
                      SelectionChanged="AuthModeComboBox_SelectionChanged"
                      Margin="0,0,0,8">
                <ComboBoxItem Content="会员登录令牌（Token）" Tag="member_token" />
                <ComboBoxItem Content="API Key" Tag="api_key" />
            </ComboBox>
            <TextBlock Text="模型提供商"
                       FontWeight="Bold"
                       Margin="0,8,0,6" />
            <ComboBox x:Name="ProviderComboBox"
                      SelectionChanged="ProviderComboBox_SelectionChanged"
                      Margin="0,0,0,8">
                <ComboBoxItem Content="OpenAI 官方" Tag="openai" />
                <ComboBoxItem Content="阿里云百炼（OpenAI 兼容）" Tag="openai_compatible" />
                <ComboBoxItem Content="自定义 OpenAI 兼容" Tag="openai_compatible" />
            </ComboBox>
            <TextBlock Text="Base URL"
                       FontWeight="Bold"
                       Margin="0,8,0,6" />
            <TextBox x:Name="BaseUrlTextBox"
                     Margin="0,0,0,8" />
            <TextBlock Text="模型类型"
                       FontWeight="Bold"
                       Margin="0,8,0,6" />
            <ComboBox x:Name="ModelPresetComboBox"
                      SelectionChanged="ModelPresetComboBox_SelectionChanged"
                      Margin="0,0,0,6">
                <ComboBoxItem Content="自定义（手动输入）" Tag="" />
                <ComboBoxItem Content="qwen3.5-plus" Tag="qwen3.5-plus" />
                <ComboBoxItem Content="kimi-k2.5" Tag="kimi-k2.5" />
                <ComboBoxItem Content="qwen3-coder-plus" Tag="qwen3-coder-plus" />
                <ComboBoxItem Content="gpt-4.1" Tag="gpt-4.1" />
            </ComboBox>
            <TextBox x:Name="ModelTypeTextBox"
                     Margin="0,0,0,8" />
            <TextBlock x:Name="CredentialLabelTextBlock"
                       Text="API Key（可选）"
                       FontWeight="Bold"
                       Margin="0,8,0,6" />
            <PasswordBox x:Name="ApiKeyPasswordBox" />
            <TextBlock x:Name="ValidationTextBlock"
                       Foreground="#FF9C2F2F"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap" />
            <UniformGrid Columns="2"
                         Margin="0,16,0,0">
                <Button Content="取消"
                        Height="32"
                        IsCancel="True"
                        Margin="0,0,6,0"
                        Click="CancelButton_Click" />
                <Button Content="确认并进入"
                        Height="32"
                        IsDefault="True"
                        Margin="6,0,0,0"
                        Click="ConfirmButton_Click" />
            </UniformGrid>
        </StackPanel>
    </Border>
</Window>
