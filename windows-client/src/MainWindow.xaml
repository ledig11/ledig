<Window x:Class="WindowsStepGuide.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Step Guide"
        Width="360"
        Height="1110"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="1520"
        Top="80"
        Background="#FFF7F7F2">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Border Padding="16">
        <StackPanel>
            <TextBlock Text="Windows Step Guide"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />
            <TextBlock Text="任务"
                       FontWeight="Bold" />
            <TextBox Text="{Binding TaskText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,6,0,12" />
            <UniformGrid Columns="4"
                         Margin="0,0,0,0">
                <Button Content="{Binding AnalyzeNextButtonText}"
                        Height="32"
                        Margin="0,0,4,0"
                        IsEnabled="{Binding CanAnalyze}"
                        Click="AnalyzeButton_Click" />
                <Button Content="{Binding ReanalyzeButtonText}"
                        x:Name="ReanalyzeButton"
                        Height="32"
                        Margin="4,0,4,0"
                        IsEnabled="{Binding CanAnalyze}"
                        Click="ReanalyzeButton_Click" />
                <Button Content="这一步不对"
                        Height="32"
                        Margin="4,0,4,0"
                        IsEnabled="{Binding CanAnalyze}"
                        Click="IncorrectStepButton_Click" />
                <Button Content="已完成"
                        Height="32"
                        Margin="4,0,0,0"
                        IsEnabled="{Binding CanAnalyze}"
                        Click="CompletedStepButton_Click" />
            </UniformGrid>
            <TextBlock Text="下一步"
                       FontWeight="Bold"
                       Margin="0,16,0,6" />
            <Border Background="#FFFFFFFF"
                    BorderBrush="#FFD8D8D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <TextBlock Text="{Binding Instruction}"
                           TextWrapping="Wrap"
                           MinHeight="56" />
            </Border>
            <TextBlock Text="Highlight"
                       FontWeight="Bold"
                       Margin="0,16,0,6" />
            <Border Background="#FFFFFFFF"
                    BorderBrush="#FFD8D8D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <TextBlock Text="{Binding HighlightText}"
                           TextWrapping="Wrap"
                           MinHeight="40" />
            </Border>
            <TextBlock Text="Preview"
                       FontWeight="Bold"
                       Margin="0,16,0,6" />
            <Border Background="#FFFDFDF9"
                    BorderBrush="#FFD8D8D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <Grid>
                    <Canvas Width="{Binding PreviewCanvasDisplayWidth}"
                            Height="{Binding PreviewCanvasDisplayHeight}"
                            Background="#FFF4F1E8"
                            Visibility="{Binding HasHighlight, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Rectangle Width="{Binding PreviewWidth}"
                                   Height="{Binding PreviewHeight}"
                                   Stroke="#FFBF5B04"
                                   StrokeThickness="2"
                                   RadiusX="4"
                                   RadiusY="4"
                                   Canvas.Left="{Binding PreviewLeft}"
                                   Canvas.Top="{Binding PreviewTop}" />
                    </Canvas>
                    <TextBlock Text="无高亮"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#FF777777"
                               FontStyle="Italic"
                               Visibility="{Binding HasNoHighlight, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Border>
            <TextBlock Text="Local Feedback"
                       FontWeight="Bold"
                       Margin="0,16,0,6" />
            <Border Background="#FFFFFFFF"
                    BorderBrush="#FFD8D8D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <TextBlock Text="{Binding LastFeedbackText}"
                           Foreground="#FF666666"
                           TextWrapping="Wrap"
                           MinHeight="64" />
            </Border>
            <TextBlock Text="Debug / Current Context"
                       FontWeight="Bold"
                       Margin="0,16,0,6" />
            <Border Background="#FFFFFFFF"
                    BorderBrush="#FFD8D8D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="{Binding CurrentSessionId, StringFormat=session_id: {0}}"
                               Foreground="#FF666666"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding CurrentStepId, StringFormat=step_id: {0}}"
                               Foreground="#FF666666"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                    <TextBlock Text="{Binding LastFeedbackType, StringFormat=last_feedback_type: {0}}"
                               Foreground="#FF666666"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                    <TextBlock Text="{Binding RuntimeModelSummary}"
                               Foreground="#FF666666"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                    <TextBlock Text="{Binding RealtimeStatus}"
                               Foreground="#FF666666"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
            <TextBlock Text="Observation Summary"
                       FontWeight="Bold"
                       Margin="0,16,0,6" />
            <Border Background="#FFFFFFFF"
                    BorderBrush="#FFD8D8D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <TextBlock Text="{Binding LastObservationSummary}"
                           Foreground="#FF666666"
                           TextWrapping="Wrap"
                           MinHeight="64" />
            </Border>
            <TextBlock Text="Observation Assets"
                       FontWeight="Bold"
                       Margin="0,16,0,6" />
            <Border Background="#FFFFFFFF"
                    BorderBrush="#FFD8D8D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <TextBlock Text="{Binding LastObservationAssetSummary}"
                           Foreground="#FF666666"
                           TextWrapping="Wrap"
                           MinHeight="64" />
            </Border>
            <TextBlock Text="Foreground Window UIA"
                       FontWeight="Bold"
                       Margin="0,16,0,6" />
            <Border Background="#FFFFFFFF"
                    BorderBrush="#FFD8D8D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <TextBlock Text="{Binding LastObservationAutomationSummary}"
                           Foreground="#FF666666"
                           TextWrapping="Wrap"
                           MinHeight="64" />
            </Border>
            <TextBlock Text="Recent Observations"
                       FontWeight="Bold"
                       Margin="0,16,0,6" />
            <Border Background="#FFFFFFFF"
                    BorderBrush="#FFD8D8D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <ScrollViewer Height="150"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding RecentObservations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#FFE6E1D6"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,0,0,8"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CapturedAtUtc, StringFormat=captured_at_utc: {0}}"
                                                   Foreground="#FF666666"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ForegroundWindowTitle, StringFormat=foreground_window_title: {0}}"
                                                   Foreground="#FF666666"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding ScreenWidth, StringFormat=screen_width: {0}}"
                                                   Foreground="#FF666666"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding ScreenHeight, StringFormat=screen_height: {0}}"
                                                   Foreground="#FF666666"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding ScreenshotRef, StringFormat=screenshot_ref: {0}}"
                                                   Foreground="#FF666666"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding ScreenshotStatus, StringFormat=screenshot_status: {0}}"
                                                   Foreground="#FF666666"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding ScreenshotLocalPath, StringFormat=screenshot_local_path: {0}}"
                                                   Foreground="#FF666666"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding AutomationControlType, StringFormat=uia_control_type: {0}}"
                                                   Foreground="#FF666666"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding AutomationClassName, StringFormat=uia_class_name: {0}}"
                                                   Foreground="#FF666666"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding AutomationId, StringFormat=uia_automation_id: {0}}"
                                                   Foreground="#FF666666"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            <TextBlock Text="{Binding StatusMessage}"
                       Margin="0,10,0,0"
                       Foreground="#FF666666"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</Window>
