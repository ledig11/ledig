{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NextStepResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "step_id",
    "instruction",
    "action_type",
    "requires_user_action"
  ],
  "properties": {
    "session_id": {
      "type": "string"
    },
    "step_id": {
      "type": "string"
    },
    "instruction": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "action_type": {
      "type": "string"
    },
    "requires_user_action": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "observation_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "highlight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rect"],
      "properties": {
        "rect": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x": {
              "type": "integer"
            },
            "y": {
              "type": "integer"
            },
            "width": {
              "type": "integer"
            },
            "height": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}
